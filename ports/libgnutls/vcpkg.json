{
  "name": "libgnutls",
  "version": "3.7.3",
  "description": "A secure communications library implementing the SSL, TLS and DTLS protocols",
  "homepage": "https://www.gnutls.org/",
  "supports": "!windows",
  "dependencies": [
    "gettext",
    "gmp",
    "libidn2",
    "libtasn1",
    "nettle",
    "dirent",
    {
          "name": "gettext",
          "host": true,
          "features": [
            "tools"
          ]                                                                        
      }
  ],
  "features": {
    "openssl": {
      "description": "enables the OpenSSL compatibility library"
    }
  }
}
